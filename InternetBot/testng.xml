<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ElementMaster Suite" parallel="tests" thread-count="5">

    <listeners>
        <listener class-name="utils.TestListener"/>
    </listeners>

    <!-- Authentication Module -->
    <test name="Authentication Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <!-- Alerts Module -->
    <test name="Alerts Tests">
        <classes>
            <class name="tests.AlertsTest"/>
        </classes>
    </test>
    
    <!-- Dropdown Module -->
    <test name="Dropdown Tests">
        <classes>
            <class name="tests.DropdownTest"/>
        </classes>
    </test>
    
    <!-- FileUpload Module -->
    <test name="File Upload Tests">
    <classes>
        <class name="tests.UploadTest"/>
    </classes>
	</test>
	
	 <!-- Dynamic Loading  Module-->
    <test name="Dynamic Loading Tests">
        <classes>
            <class name="tests.DynamicTest"/>
        </classes>
    </test>

</suite> <!-- Suite -->
